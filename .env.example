# Update these with your Supabase details from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

CLIENT_ID=
CLIENT_SECRET=

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ============================================================================
# ChefPlan API Keys (for real recipe and nutrition data)
# ============================================================================

# Spoonacular API - Recipes, meal planning, nutrition
# Get free key at: https://spoonacular.com/food-api (150 requests/day free)
SPOONACULAR_API_KEY=

# USDA FoodData Central API - Official US nutrition database
# Get free key at: https://fdc.nal.usda.gov/api-key-signup.html
# Leave empty to use DEMO_KEY (rate limited)
USDA_API_KEY=

# Note: TheMealDB and Open Food Facts APIs are completely free and don't require keys



